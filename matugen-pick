#!/usr/bin/env bash
# matugen-pick: browse a wallpaper folder with fzf (kitty image preview),
# set the picked image as the macOS desktop wallpaper via desktoppr, then
# hand off to matugen which will prompt for the source color and regenerate
# nvim + kitty themes.
#
# Usage: matugen-pick [DIR]   (default: ~/Documents/backgrounds)

set -euo pipefail

dir="${1:-$HOME/Documents/backgrounds}"
cd "$dir"

shopt -s nullglob nocaseglob
files=(*.jpg *.jpeg *.png *.webp *.heic)
shopt -u nullglob nocaseglob

((${#files[@]})) || {
	echo "no images in $dir" >&2
	exit 1
}

pick=$(printf '%s\n' "${files[@]}" | fzf \
	--prompt='wallpaper> ' \
	--preview-window='right:60%' \
	--preview='kitten icat --clear --transfer-mode=memory --stdin=no --place=${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}@0x0 {}') || exit 0

path="$dir/$pick"
desktoppr "$path"
matugen image "$path"
